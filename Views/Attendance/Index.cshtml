@model IEnumerable<Kintai.Models.Attendance>

@{
    ViewData["Title"] = "勤怠一覧";
}

<h1>勤怠一覧</h1>

<p>
    <a asp-action="Create">新規作成</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                勤務日
            </th>
            <th>
                出勤
            </th>
            <th>
                退勤
            </th>
            <th>
                社員
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @item.WorkDate.ToString("yyyy-MM-dd")
            </td>
            <td>
                @item.ClockIn?.ToString("HH:mm")
            </td>
            <td>
                @item.ClockOut?.ToString("HH:mm")
            </td>
            <td>
                @item.User?.FullName
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">編集</a> |
                <a asp-action="Details" asp-route-id="@item.Id">詳細</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">削除</a>
            </td>
        </tr>
}
    </tbody>
</table>
