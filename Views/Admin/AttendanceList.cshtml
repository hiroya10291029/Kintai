@model IEnumerable<Kintai.Models.Attendance>

@{
    ViewData["Title"] = "勤怠一覧（管理者）";
}

<h2>勤怠一覧（管理者）</h2>

<form method="get" class="mb-3">
    <label>社員名（部分一致）：</label>
    <input type="text" name="nameKeyword" value="@Context.Request.Query["nameKeyword"]" />

    <label class="ms-3">日付：</label>
    <input type="date" name="date" value="@Context.Request.Query["date"]" />

    <button type="submit" class="btn btn-primary ms-3">検索</button>
</form>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>社員名</th>
            <th>日付</th>
            <th>出勤</th>
            <th>退勤</th>
            <th>勤務時間</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Model)
        {
            <tr>
                <td>@a.User?.FullName</td>
                <td>@a.WorkDate.ToString("yyyy-MM-dd")</td>
                <td>@a.ClockIn?.ToString("HH:mm")</td>
                <td>@a.ClockOut?.ToString("HH:mm")</td>
                <td>@a.WorkingHours.ToString(@"hh\:mm")</td>
            </tr>
        }
    </tbody>
</table>
