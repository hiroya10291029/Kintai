<h2>社員登録</h2>

<form method="post">
    <div class="form-group">
        <label>氏名</label>
        <input name="fullName" class="form-control" />
    </div>

    <div class="form-group">
        <label>Email</label>
        <input name="email" class="form-control" />
    </div>

    <div class="form-group">
        <label>パスワード</label>
        <input name="password" type="password" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">登録</button>
</form>
